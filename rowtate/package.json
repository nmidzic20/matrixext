{
  "name": "rowtate",
  "displayName": "rowtate",
  "description": "Transpose long rows in CSV files for easier key-value editing",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.106.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:rowtate.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rowtate",
          "title": "Rowtate",
          "icon": "media/rowtate.svg"
        }
      ]
    },
    "views": {
      "rowtate": [
        {
          "id": "rowtate.sidebar",
          "name": "Controls",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Rowtate",
      "properties": {
        "rowtate.colors.comment": {
          "type": "string",
          "default": "#87c66b",
          "description": "Rowtate comment color (e.g. #87c66b)."
        },
        "rowtate.colors.key": {
          "type": "string",
          "default": "#cd6060ff",
          "description": "Rowtate key color (e.g. #cd6060ff)."
        },
        "rowtate.colors.value": {
          "type": "string",
          "default": "#6aa2f7ff",
          "description": "Rowtate value color (e.g. #6aa2f7ff)."
        },
        "rowtate.colors.target": {
          "type": "string",
          "enum": [
            "user",
            "workspace"
          ],
          "default": "user",
          "description": "Where Rowtate saves picked colors."
        }
      }
    },
    "commands": [
      {
        "command": "rowtate.toggle",
        "title": "Rowtate: Toggle Key/Value Layout"
      },
      {
        "command": "rowtate.toggleColoring",
        "title": "Rowtate: Toggle Coloring"
      },
      {
        "command": "rowtate.reorderVertical",
        "title": "Rowtate: Reorder Rows (Vertical Drag & Drop)"
      },
      {
        "command": "rowtate.blocksToVertical",
        "title": "Rowtate: Convert Selected Blocks to Vertical"
      },
      {
        "command": "rowtate.blocksToHorizontal",
        "title": "Rowtate: Convert Selected Blocks to Horizontal"
      },
      {
        "command": "rowtate.pickColors",
        "title": "Rowtate: Pick Colors"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.106.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.46.3",
    "eslint": "^9.39.1",
    "esbuild": "^0.27.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
